# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Frontend (Next.js) ──────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# ── Backend (Django) ────────────────────────────────
backend/.venv/
backend/__pycache__/
backend/*/__pycache__/
backend/*/*/__pycache__/
backend/db.sqlite3
backend/media/
backend/staticfiles/
*.pyc
*.pyo

# ── Shared ──────────────────────────────────────────
# dependencies
node_modules/

# testing
/coverage

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example, ignore .env and .env.local)
.env
.env.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Guides
/docs
/sampleCode
AGENTS.md
CLAUDE.md

# Excels
sample\ template.xlsx
Web\ application\ format.xlsx